# Local development
VITE_API_URL=http://localhost:5000/api/v1

# Production (Vercel) - REQUIRED: set in Vercel Environment Variables before deploy
# Option 1 (recommended - full API path):
# VITE_API_URL=https://your-backend.onrender.com/api/v1
#
# Option 2 (also works - backend host only, /api/v1 is added automatically):
# VITE_API_URL=https://your-backend.onrender.com
